{
  "name": "key-project-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "check": "for f in src/routes/*.js src/services/*.js src/lib/*.js src/middleware/*.js src/app.js src/server.js app.js src/ui/*.js; do node --check \"$f\" || exit 1; done",
    "test": "node --test tests/*.test.js tests/**/*.test.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node scripts/seed-from-data.mjs",
    "feishu:chat-members": "node scripts/fetch-feishu-chat-members.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "prisma": "^5.15.0"
  }
}
